<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section page-width-content color-{{ section.settings.color_scheme }}">
  <div
    class="
      spacing-style
      layout-panel-flex
      layout-panel-flex--column
      section-content-wrapper
      mobile-column
    "
    style="
      {% render 'layout-panel-style', settings: section.settings %}
      {% render 'spacing-style', settings: section.settings %}
    "
  >
    {% content_for 'blocks' %}
  </div>
</div>

{% if page.handle == 'reuse-old-wired-alarm-sensors-smart-home' %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Can I reuse old wired alarm sensors?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Door/window contacts and wired motion sensors are often reusable with a Konnected Alarm Panel when they are truly wired and in usable condition."
          }
        },
        {
          "@type": "Question",
          "name": "Can old alarm sensors work with Home Assistant?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. With compatible Konnected hardware, wired alarm sensors can report activity to smart-home platforms including Home Assistant."
          }
        },
        {
          "@type": "Question",
          "name": "Can I reuse wireless alarm sensors?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Existing wireless sensors from a legacy alarm company are not compatible with Konnected alarm panel products. Konnected is built for wired sensor networks."
          }
        },
        {
          "@type": "Question",
          "name": "What alarm devices need extra caution?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Smoke, CO, fire, monitored, powered, keypad, glass-break, unknown, or other life-safety wiring deserves extra caution before moving wires or connecting devices to a smart-home system."
          }
        }
      ]
    }
  </script>
{% endif %}

{% schema %}
{
  "name": "t:names.page",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "column",
          "label": "t:options.vertical"
        }
      ],
      "default": "column",
      "visible_if": "{{ section.settings.gap < 0 }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
