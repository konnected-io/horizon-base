{%- doc -%}
  Renders a wrapper section

  @param {section} section - The section object
  @param {string} children - The children of the section
{%- enddoc -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  {% if section.settings.add_section_id == true and section.settings.section_id != blank %}
    data-section-id="{{ section.settings.section_id }}"
  {% endif %}
  class="section  {% if section.settings.full_width_on_mobile %}section--mobile-full-width{% endif %} section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} {{ section.settings.css_class }}"
  data-testid="ui-test-section"

  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}

  style="
    {% if section.settings.section_height == 'custom' %}
      --section-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      --section-min-height: 100svh;
    {% elsif section.settings.section_height != '' %}
      --section-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}

    {% if section.settings.section_height != '' %}
     --section-preview-height: 600px;
     {% endif %}
  "
>
  <div class="custom-section-background">
    {% render 'background-media',
      background_media: section.settings.background_media,
      background_video: section.settings.video,
      background_video_position: section.settings.video_position,
      background_image: section.settings.background_image,
      background_image_position: section.settings.background_image_position
    %}
  </div>

  <div
    class="border-style custom-section-content"
    style="{% render 'border-override', settings: section.settings %}"
  >
    {% if section.settings.toggle_overlay %}
      {% render 'overlay', settings: section.settings, layer: '0' %}
    {% endif %}

    <div
      class="
        spacing-style
        layout-panel-flex
        layout-panel-flex--{{ section.settings.content_direction }}
        section-content-wrapper
        {% if section.settings.reverse_on_mobile == true %}mobile-section-column-reverse{% endif %}
        {% if section.settings.vertical_on_mobile %} mobile-column{% endif %}
      "
      style="
        {% render 'layout-panel-style', settings: section.settings %}
        {% render 'spacing-style', settings: section.settings %}
      "
      data-testid="section-content"
    >
      {{ children }}
    </div>
  </div>
</div>

{% stylesheet %}
  .section-wrapper {
    --section-height-offset: 0px;
  }

  .section[data-shopify-visual-preview] {
    min-height: var(--section-preview-height);
    padding-top: 0;
  }

  .section[data-shopify-visual-preview] .custom-section-background {
    display: none;
  }

  body:has(> #header-group > .header-section > #header-component[transparent]):not(
      :has(> #header-group > .header-section + .shopify-section)
    )
    > main
    > .section-wrapper:first-child {
    --section-height-offset: var(--header-group-height, 0);
  }

  .custom-section-background {
    grid-column: 1 / -1;
  }

  .custom-section-content {
    z-index: var(--layer-flat);
  }

  .gdo-decision-guide .section-content-wrapper {
    max-width: 960px;
    margin-inline: auto;
    padding: clamp(22px, 3vw, 34px);
    border: 1px solid rgb(var(--color-foreground-rgb) / 12%);
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-background) 94%, var(--color-foreground) 6%);
  }

  .gdo-decision-guide .text-block h2 {
    margin-block-end: 0;
  }

  .gdo-decision-guide .gdo-decision-path-grid {
    width: 100%;
  }

  .gdo-decision-guide .gdo-decision-path-grid .group-block-content {
    align-items: stretch;
  }

  .gdo-decision-guide .gdo-decision-path-card {
    min-width: 0;
    padding: 14px 16px;
    border: 1px solid rgb(var(--color-foreground-rgb) / 10%);
    border-radius: 8px;
    background: rgb(var(--color-background-rgb) / 76%);
    transition:
      border-color var(--animation-speed-fast) var(--animation-easing),
      transform var(--animation-speed-fast) var(--animation-easing);
  }

  .gdo-decision-guide .gdo-decision-path-card:hover {
    border-color: rgb(var(--color-foreground-rgb) / 22%);
    transform: translateY(-1px);
  }

  .gdo-decision-guide .gdo-decision-path-card .text-block:first-child {
    color: rgb(var(--color-foreground-rgb) / 56%);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .gdo-decision-guide .gdo-decision-path-card .text-block:last-child {
    color: rgb(var(--color-foreground-rgb) / 72%);
  }

  .gdo-decision-guide .accordion {
    margin-block-start: 0;
    border-block-start: 1px solid rgb(var(--color-foreground-rgb) / 14%);
  }

  .gdo-decision-guide .details {
    border-block-end: 1px solid rgb(var(--color-foreground-rgb) / 10%);
  }

  .gdo-decision-guide .details__header {
    min-height: auto;
    padding: 13px 10px;
    gap: 12px;
    font-weight: 650;
    border-radius: 6px;
    transition: background-color var(--animation-speed-fast) var(--animation-easing);
  }

  .gdo-decision-guide .details__header:hover {
    background-color: rgb(var(--color-foreground-rgb) / 4%);
  }

  .gdo-decision-guide .details__icon {
    display: none;
  }

  .gdo-decision-guide .details-content {
    padding-block-end: 14px;
    padding-inline-end: clamp(0px, 6vw, 72px);
    padding-inline-start: 10px;
  }

  .gdo-decision-guide .details-content .text-block {
    color: rgb(var(--color-foreground-rgb) / 86%);
  }

  @media screen and (max-width: 749px) {
    .gdo-decision-guide .section-content-wrapper {
      padding: 22px 20px;
      border-inline: 0;
      border-radius: 0;
    }

    .gdo-decision-guide .gdo-decision-path-card {
      padding: 11px 13px;
    }

    .gdo-decision-guide .details__header {
      padding: 13px 0;
    }

    .gdo-decision-guide .details-content {
      padding-inline-start: 0;
    }
  }
{% endstylesheet %}
