{% comment %}
  Konnected accent CSS custom properties, sourced from the theme color palette.

  Horizon v4 replaced the per-scheme color model with a single `color_palette`
  and dropped the `--color-primary` / `--color-foreground-heading` custom
  properties that v3 emitted per scheme. Konnected content and custom blocks
  (text-icon, timeline, tables, reseller/installer items, header buttons,
  grid-section headings) still consume them, so we define them here from the
  palette's `konnected_blue` entry — a single source of truth the merchant edits
  in the theme editor's color palette.
{% endcomment %}
{% style %}
  :root {
    --color-primary: {{ settings.color_palette.konnected_blue }};
    --color-primary-rgb: {{ settings.color_palette.konnected_blue.rgb }};
    --color-primary-hover: {{ settings.color_palette.konnected_blue }};
    --color-primary-active: {{ settings.color_palette.konnected_blue }};

    /* Accent headings are brand-colored (matches the live theme). */
    --color-foreground-heading: {{ settings.color_palette.konnected_blue }};

    /* v4 ties --color-border to page_text_color (near-black); the brand uses a
       light neutral border. contrast-override still overrides this per-section
       on colored backgrounds. */
    --color-border: {{ settings.color_palette.border }};
    --color-border-rgb: {{ settings.color_palette.border.rgb }};

    /* 2026 refresh: additional palette entries consumed by the k-* components
       in custom.css (hero, stats, reveal). Same single-source-of-truth rule. */
    --color-brand-tint: {{ settings.color_palette.brand_tint }};
    --color-midnight: {{ settings.color_palette.midnight_blue }};
    --color-midnight-rgb: {{ settings.color_palette.midnight_blue.rgb }};
    --color-electric-cyan: {{ settings.color_palette.electric_cyan }};
    --color-electric-cyan-rgb: {{ settings.color_palette.electric_cyan.rgb }};
    --color-circuit-green: {{ settings.color_palette.circuit_green }};
  }
{% endstyle %}
