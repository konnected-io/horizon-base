{% doc %}
  Adds Konnected-specific metadata hints for article discovery surfaces without replacing Shopify's default meta tags or structured data.
{% enddoc %}

<meta
  name="robots"
  content="max-image-preview:large"
>

{%- if request.page_type == 'article' -%}
  <meta
    property="article:published_time"
    content="{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}"
  >
  <meta
    property="article:modified_time"
    content="{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S%z' }}"
  >

  {%- if page_image -%}
    <meta
      name="twitter:image"
      content="https:{{ page_image | image_url }}"
    >
  {%- endif -%}
{%- endif -%}
