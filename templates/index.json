    "custom_hero_duo": {
      "type": "custom-liquid",
      "name": "Hero: dual product lines",
      "custom_css": [
        ".section-background {background: radial-gradient(circle 240px at 91% -70px, transparent 58%, rgba(34,190,255,.26) 60%, rgba(63,117,255,.15) 74%, transparent 76%), radial-gradient(circle 260px at 3% 108%, transparent 60%, rgba(63,117,255,.18) 62%, rgba(34,190,255,.09) 76%, transparent 78%), radial-gradient(640px 420px at 88% -10%, rgba(34,190,255,.12), transparent 65%), linear-gradient(180deg, #ffffff 0%, #eef4f9 100%);}"
      ],
      "settings": {
        "custom_liquid": "<div class=\"k-hero\"><div class=\"k-hero__head\"><div class=\"k-hero__intro\"><h2 class=\"k-hero__title\">Breathe new life into the wiring your home <em>already has</em>.</h2><p class=\"k-hero__sub\">Konnected retrofits two things every house already owns: the <strong>wired alarm system</strong> and the <strong>garage door opener</strong>. No subscriptions, no cloud lock-in.</p></div><aside class=\"k-hero__proof\"><p class=\"k-hero__stars\" role=\"img\" aria-label=\"Rated 5 out of 5 stars\">&#9733;&#9733;&#9733;&#9733;&#9733;</p><div class=\"k-quote-rotator\"><figure class=\"k-quote is-active\"><blockquote>“Worked exactly as expected right out of the box. I can’t rate this cloudless, subscription-less device highly enough.”</blockquote><figcaption>Josh P. - Verified customer</figcaption></figure><figure class=\"k-quote\"><blockquote>“Love this product! My alarm is now totally integrated with my other smart home devices and platforms.”</blockquote><figcaption>Martin J. - Verified customer</figcaption></figure><figure class=\"k-quote\"><blockquote>“I got my GDO blaQs! 2x installed in under 15 mins. It’s amazing how quickly I had full integration with all my smart home services.”</blockquote><figcaption>Anthony P. - Verified customer</figcaption></figure><figure class=\"k-quote\"><blockquote>“The Konnected Pro and Interface Boards work perfectly. App interface to SmartThings work perfectly.”</blockquote><figcaption>David L. - Verified customer</figcaption></figure><figure class=\"k-quote\"><blockquote>“Very consistent and works without fail! I recommend it for anyone using SmartThings.”</blockquote><figcaption>Aaron P. - Verified customer</figcaption></figure><figure class=\"k-quote\"><blockquote>“The hardware works great and is super easy to setup. I use my Alarm Panel Pro integrated with Home Assistant and love the built in integration!”</blockquote><figcaption>Jedidiah H. - Verified customer</figcaption></figure></div><div class=\"k-hero__badges\"><img src=\"{{ 'Works_With_HA_-_Generic.png' | file_img_url: '400x' }}\" alt=\"Works with Home Assistant\" loading=\"lazy\"><img src=\"{{ '1._works-with-smart-things.png' | file_img_url: '400x' }}\" alt=\"Works with SmartThings\" loading=\"lazy\"></div></aside></div><div class=\"k-hero__duo\"><article class=\"k-line-card k-reveal\"><a class=\"k-line-card__media-link\" href=\"/collections/smart-alarm-panels\" tabindex=\"-1\" aria-hidden=\"true\"><img class=\"k-line-card__img k-line-card__img--alarm\" src=\"{{ 'smart_alarm_panels.png' | file_img_url: '900x' }}\" alt=\"Konnected Alarm Panel Pro board\" fetchpriority=\"high\"></a><h3 class=\"k-line-card__title\">Smart Alarm Panels</h3><p class=\"k-line-card__text\">Every wired door, window, and motion sensor in your walls becomes a smart sensor in the app you already use.</p><div class=\"k-line-card__row\"><a class=\"button\" href=\"/collections/smart-alarm-panels\">Shop Alarm Panels</a><span class=\"k-line-card__note\">From DIY retrofit to new builds</span></div></article><article class=\"k-line-card k-reveal\"><a class=\"k-line-card__media-link\" href=\"/collections/smart-garage-door-openers\" tabindex=\"-1\" aria-hidden=\"true\"><img class=\"k-line-card__img\" src=\"{{ 'Smart_Garage_Openers.png' | file_img_url: '900x' }}\" alt=\"Konnected GDO blaQ and GDO White smart garage controllers\" fetchpriority=\"high\"></a><h3 class=\"k-line-card__title\">Smart Garage Openers</h3><p class=\"k-line-card__text\">Retrofit the opener you already own with local control, real-time door status, and automations.</p><div class=\"k-line-card__row\"><a class=\"button\" href=\"/collections/smart-garage-door-openers\">Shop Garage Openers</a><span class=\"k-line-card__note\">Works with most major brands</span></div></article></div></div>",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "custom_stats": {
      "type": "custom-liquid",
      "name": "Konnected in numbers",
      "settings": {
        "custom_liquid": "<div class=\"k-stats\"><h2 class=\"k-stats__title\">Konnected in numbers</h2><div class=\"k-stats__grid\"><div class=\"k-stat k-reveal\"><span class=\"k-stat__n\">9</span><span class=\"k-stat__l\">Smart home integrations</span></div><div class=\"k-stat k-reveal\"><span class=\"k-stat__n\">$780</span><span class=\"k-stat__l\">Average yearly savings</span></div><div class=\"k-stat k-reveal\"><span class=\"k-stat__n\">+25k</span><span class=\"k-stat__l\">Konnected cloud users</span></div><div class=\"k-stat k-reveal\"><span class=\"k-stat__n\">60+</span><span class=\"k-stat__l\">Countries shipped to</span></div><div class=\"k-stat k-reveal\"><span class=\"k-stat__n\">~1hr</span><span class=\"k-stat__l\">Estimated install</span></div></div></div>",
        "section_width": "page-width",
        "padding-block-start": 64,
