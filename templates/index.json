      }
    },
    "custom_quiz": {
      "type": "custom-liquid",
      "name": "Quiz CTA",
      "settings": {
        "custom_liquid": "<div class=\"k-quiz k-reveal\"><h2 class=\"k-quiz__title\">Not sure which product is right for you?</h2><p class=\"k-quiz__sub\">Take a short quiz and we&rsquo;ll point you to the right kit for your home.</p><div class=\"k-quiz__actions\"><div class=\"okeQuizModalButton\" style=\"display:flex;\"><a href=\"#\" onclick=\"okeConnectApi.showQuiz('7f8f415c-2756-4637-8119-aa24df66b6b7', '1d0a586e-45b1-4a7e-b30d-539e2e1abc0e')\" class=\"button\">Alarm panel quiz</a></div><div class=\"okeQuizModalButton\" style=\"display:flex;\"><a href=\"#\" onclick=\"okeConnectApi.showQuiz('d515c056-caae-4c7d-8890-d9fcc8947b62', '1d0a586e-45b1-4a7e-b30d-539e2e1abc0e')\" class=\"button\">Garage opener quiz</a></div></div></div>",
